{
  "name": "@catalog/client",
  "version": "1.0.0",
  "description": "SDK for communicating with the Catalog Engine API - a language binding for frontend applications",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "browser": "./dist/index.browser.global.js",
  "exports": {
    ".": {
      "require": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "import": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      }
    }
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/your-org/catalog-client.git"
  },
  "homepage": "https://github.com/your-org/catalog-client",
  "keywords": [
    "catalog",
    "search",
    "sdk",
    "api",
    "typescript",
    "javascript",
    "browser",
    "node"
  ],
  "license": "MIT",
  "devDependencies": {
    "tsup": "^8.0.0",
    "typescript": "^5.5.0",
    "vitest": "^2.0.0"
  },
  "scripts": {
    "build": "rm -rf dist && tsup ./src/index.ts --format cjs,esm --dts --clean && tsup ./src/index.browser.ts --format iife --global-name CatalogClient --sourcemap",
    "prepublishOnly": "npm run build",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "engines": {
    "node": ">=18"
  }
}
